{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run frontend:build",
    "watchPatterns": ["frontend/**"]
  },
  "deploy": {
    "startCommand": "npm run frontend:start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
